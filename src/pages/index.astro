---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../utils/format-date';

const isDev = import.meta.env.DEV;
const posts = (await getCollection('blog', ({ data }) => isDev || !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
).slice(0, 3);

const features = [
  { title: 'Lightning Fast', description: 'Zero JavaScript by default. Ship only what you need for blazing-fast load times.', icon: '⚡' },
  { title: 'SEO Optimized', description: 'Static HTML output with full control over meta tags, structured data, and sitemap.', icon: '🔍' },
  { title: 'Content Collections', description: 'Type-safe Markdown and MDX content with schema validation built in.', icon: '📚' },
  { title: 'Tailwind CSS', description: 'Utility-first CSS framework for rapid, consistent, and responsive styling.', icon: '🎨' },
  { title: 'TypeScript', description: 'Full TypeScript support with strict mode for a safer, more productive workflow.', icon: '🛡️' },
  { title: 'Deploy Anywhere', description: 'Static output deploys to any CDN, server, or hosting platform.', icon: '🌍' },
];

const siteUrl = Astro.site?.href ?? Astro.url.origin + '/';
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "AstroStatic",
  "url": siteUrl,
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${siteUrl}search?q={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
};
---

<BaseLayout
  title="AstroStatic - Content-First Static Sites"
  description="Astro 6 + Tailwind CSS starter template for content-heavy static sites. Includes blog, content collections, full-text search, RSS, and dark mode."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </Fragment>
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-4 py-20 text-center">
    <h1 class="text-5xl font-extrabold tracking-tight sm:text-6xl">
      Build <span class="text-blue-600 dark:text-blue-400">content-first</span> static sites
    </h1>
    <p class="mt-6 text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
      Astro 6 + Tailwind CSS starter with blog support, content collections, and optimized static output. Ship fast, write content, iterate quickly.
    </p>
    <div class="mt-8 flex gap-4 justify-center">
      <a href="/blog" class="rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white hover:bg-blue-700 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500">
        Read the Blog
      </a>
      <a href="https://docs.astro.build" target="_blank" rel="noopener noreferrer" class="rounded-lg border border-gray-300 dark:border-gray-700 px-6 py-3 text-sm font-semibold hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500">
        Astro Docs
      </a>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="mx-auto max-w-5xl px-4 py-16">
    <h2 class="text-3xl font-bold text-center mb-12">Why this starter?</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class="rounded-xl border border-gray-200 dark:border-gray-800 p-6 hover:shadow-lg transition-shadow">
          <div class="text-3xl mb-3" aria-hidden="true">{feature.icon}</div>
          <h3 class="text-lg font-semibold mb-2">{feature.title}</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">{feature.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Latest Posts -->
  {posts.length > 0 && (
    <section class="mx-auto max-w-5xl px-4 py-16">
      <h2 class="text-3xl font-bold text-center mb-12">Latest Posts</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="group rounded-xl border border-gray-200 dark:border-gray-800 p-6 hover:shadow-lg transition-shadow focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500">
            <time datetime={post.data.date.toISOString().split('T')[0]} class="text-xs text-gray-500 dark:text-gray-400">
              {formatDate(post.data.date)}
            </time>
            <h3 class="mt-2 text-lg font-semibold group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
              {post.data.title}
            </h3>
            <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">{post.data.description}</p>
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/blog" class="text-sm font-medium text-blue-600 dark:text-blue-400 hover:underline rounded focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 dark:focus-visible:outline-blue-400">
          View all posts &rarr;
        </a>
      </div>
    </section>
  )}
</BaseLayout>
